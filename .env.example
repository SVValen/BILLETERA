# URL pública del sitio (usada en el link de login por email)
NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app

# Supabase - https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxx   # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxx        # "service_role" key (privada)

# Telegram - obtenido de @BotFather
TELEGRAM_TOKEN=123456:ABCxyz

# Groq Whisper - transcripción de audios, gratis en console.groq.com
GROQ_API_KEY=gsk_xxxxx

# Cron secret - protege el endpoint /api/cron (obligatorio, generá uno random)
CRON_SECRET=cualquier-string-secreto

# IOL (Invertir Online) - para cotizaciones de CEDEARs y acciones argentinas
IOL_USER=tu-email@ejemplo.com
IOL_PASSWORD=tu-contraseña

# Anthropic Claude API - para recomendaciones de inversión
# Obtener en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Webhook secret - protege el endpoint /api/telegram de requests falsos (requerido)
# 1. Generá un string random y poné el mismo valor aquí y en el paso siguiente
# 2. Re-registrá el webhook: https://api.telegram.org/bot<TOKEN>/setWebhook
#    con secret_token=TELEGRAM_WEBHOOK_SECRET
TELEGRAM_WEBHOOK_SECRET=otro-string-secreto
